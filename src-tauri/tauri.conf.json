{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vynta",
  "version": "1.1.0",
  "identifier": "com.dderas.vynta",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vynta",
        "maximized": true,
        "visible": true,
        "center": true,
        "focus": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost blob: data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval';"
    }
  },
  "bundle": {
    "publisher": "DDeras",
    "copyright": "Copyright © 2026 DDeras",
    "shortDescription": "Productivity application for drawing on screen.",
    "longDescription": "Vynta is a productivity application designed to facilitate screen drawing, annotations, and desktop tools useful for presentations and tutorials.",
    "category": "Utility",
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "licenseFile": "installer_assets/LICENSE.txt",
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer_assets/vynta_150x57.bmp",
        "sidebarImage": "installer_assets/vynta_164x314.bmp",
        "displayLanguageSelector": true
      },
      "wix": {
        "language": [
          "en-US"
        ],
        "bannerPath": "installer_assets/vynta_493x58.bmp",
        "dialogImagePath": "installer_assets/vynta_493x312.bmp"
      }
    }
  }
}
